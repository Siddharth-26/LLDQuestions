public class EqualSplitCalculationStrategyImpl implements IExpenseCalculatorStrategy{
        public HashMap<Integer, double> calculateAmount(HashMap<Integer, double> amountMap, double amount){
                   int size = amountMap.keySet().size();
                   int share = amount/size;
                   HashMap<Integer, double> shareMapping = new HashMap<>();
                   for(int userId : new ArrayList<>(amountMap.keySet())){
                           shareMapping.put(userId, share);
                    }
                   return shareMapping;
            }
    }

