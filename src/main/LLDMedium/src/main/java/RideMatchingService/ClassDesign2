public matchDrivers(Booking){

    List<Drivers> candidates = this.driverMatchingStrategy.getDriver(Booking)
    // for each driver in candidates
     // update the booking with the current candidate
     // send the request to the current candidate with a timeout
    synchronised(Booking)
    for (Driver driver: candidates){
           booking.setCndidate(driver);
        driver.sendNotification(Booking);
        wait(10);
    }


}
