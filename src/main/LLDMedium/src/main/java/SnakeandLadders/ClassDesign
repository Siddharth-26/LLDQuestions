public synchronised String rollDice(Player player){
    if(this.currentPlayer.getID()!=player.getId()){
        return "This is not your turn, " + currentPlayer.getName() +" please take your turn";
    }
    else{
        int moveBy = this.dice.rollDice();
        int currentPosition = this.movePlayer(moveBy);
        if(this.winningStrategy.hasWon(currentPosition)){
            return "Congratulations you have won the game, lets restart with a new game."
        }
        else{
            this.pointer+=1;
            this.pointer%=this.players.size();
            this.currentPlayer = this.players.get(this.pointer);
            return this.currentPlayer.getName()+"Please take your turn";
        }
    }
    }

